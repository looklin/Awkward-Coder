---
import Post from "../components/Post.astro";

const { allPosts } = Astro.props;

let posts = allPosts
	.sort(
		(a, b) =>
			new Date(b.data.updated || b.data.added).valueOf() -
			new Date(a.data.updated || a.data.added).valueOf(),
	)
	.slice(0, 5);
---

<content>
	<ul class="posts-list">
		{
			posts.map(
				({
					url,
					data: { description, slug, title, tags, added: date },
				}) => <Post {url} {description} {date} {slug} {title} {tags} />
			)
		}
	</ul>

	{allPosts.length > 5 && (
		<div class="view-all">
			<a href="/posts">查看全部 {allPosts.length} 篇文章 →</a>
		</div>
	)}
</content>

<style>
	.view-all {
		text-align: center;
		margin: 20px 0 40px;
	}
	.view-all a {
		font-size: 1.1em;
	}
	.view-all a:hover {
		font-weight: bold;
	}
</style>
